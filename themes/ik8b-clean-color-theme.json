{
  "$schema": "vscode://schemas/color-theme",
  "name": "ik8b Clean",
  "type": "dark",
  "colors": {
    "editor.background": "#111417",
    "editor.foreground": "#D7DEE7",
    "editorLineNumber.foreground": "#5E6977",
    "editorLineNumber.activeForeground": "#93A4B8",
    "editor.selectionBackground": "#213247",
    "editor.inactiveSelectionBackground": "#1A2634",
    "editorCursor.foreground": "#F5F7FA"
  },
  "tokenColors": [
    {
      "scope": ["comment.line.number-sign.ik8b"],
      "settings": { "foreground": "#6F8398" }
    },
    {
      "scope": ["keyword.control.ik8b", "keyword.control.conditional.ik8b", "keyword.control.flow.ik8b"],
      "settings": { "foreground": "#63C3FF", "fontStyle": "bold" }
    },
    {
      "scope": ["storage.type.ik8b"],
      "settings": { "foreground": "#7EE787" }
    },
    {
      "scope": ["constant.language.boolean.ik8b", "constant.numeric.hex.ik8b", "constant.numeric.decimal.ik8b"],
      "settings": { "foreground": "#F2CC60" }
    },
    {
      "scope": ["string.quoted.single.ik8b", "constant.character.escape.ik8b"],
      "settings": { "foreground": "#F29E74" }
    },
    {
      "scope": ["keyword.operator.assignment.ik8b"],
      "settings": { "foreground": "#FF8A65", "fontStyle": "bold" }
    },
    {
      "scope": ["keyword.operator.comparison.ik8b", "keyword.operator.logical.ik8b", "keyword.operator.bitwise.ik8b", "keyword.operator.arithmetic.ik8b", "keyword.operator.wildcard.ik8b"],
      "settings": { "foreground": "#A6B3C2" }
    },
    {
      "scope": ["support.function.builtin.ik8b"],
      "settings": { "foreground": "#FF7AB2", "fontStyle": "bold" }
    },
    {
      "scope": ["entity.name.function.ik8b"],
      "settings": { "foreground": "#B392F0" }
    },
    {
      "scope": ["constant.other.hardware-register.ik8b"],
      "settings": { "foreground": "#FFB86C", "fontStyle": "bold" }
    },
    {
      "scope": ["variable.other.constant.register.ik8b"],
      "settings": { "foreground": "#E5A65B" }
    },
    {
      "scope": ["variable.other.readwrite.ik8b"],
      "settings": { "foreground": "#9CDCFE" }
    },
    {
      "scope": ["entity.name.namespace.ik8b"],
      "settings": { "foreground": "#4FD6BE", "fontStyle": "bold" }
    }
  ]
}
